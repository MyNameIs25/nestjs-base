NODE_ENV="development"
SERVICE_NAME="auth"
PORT=3000

# Database
DB_HOST=postgres
DB_PORT=5432
DB_NAME=auth_db
DB_USER=postgres
DB_PASSWORD=postgres

# Logger (Optional)
LOG_LEVEL=debug
LOG_TO_FILE=true
LOG_DIR=logs
LOG_RETENTION_DAYS=7

# JWT
JWT_SECRET=super-secret-key-change-in-production-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Security
CORS_ORIGIN=
